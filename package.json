    "axios": "^1.18.1",
    "express": "^5.2.1",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "pg-promise": "^12.6.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
